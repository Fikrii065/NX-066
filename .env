# ── Server ───────────────────────────────────────────
PORT=3000
APP_URL=https://nx-066-production.up.railway.app

# ── Database (MySQL) ──────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=gameflash
DB_USER=root
DB_PASS=

# ── Digiflazz ─────────────────────────────────────────
DIGIFLAZZ_USERNAME=your_username
DIGIFLAZZ_API_KEY_PROD=your_prod_api_key
DIGIFLAZZ_API_KEY_DEV=your_dev_api_key
DIGIFLAZZ_MODE=production
DIGIFLAZZ_WEBHOOK_SECRET=your_webhook_secret

# ── Tokopay ───────────────────────────────────────────
TOKOPAY_MERCHANT_ID=your_merchant_id
TOKOPAY_SECRET_KEY=your_secret_key

# ── VIP Reseller ──────────────────────────────────────
VIPRESELLER_API_ID=your_api_id
VIPRESELLER_API_KEY=your_api_key

# ── JWT — WAJIB DIISI sebelum menjalankan server ──────
# Generate dengan perintah ini di terminal VPS kamu:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Salin hasilnya ke bawah ini:
JWT_SECRET=GANTI_DENGAN_OUTPUT_PERINTAH_DI_ATAS
JWT_EXPIRES_IN=8h

# ── Fonnte WhatsApp ───────────────────────────────────
FONNTE_TOKEN=your_fonnte_token
FONNTE_DEVICE=
